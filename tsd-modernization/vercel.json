{
  "rewrites": [
    { "source": "/audit", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/audit" },
    { "source": "/audit/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/audit/:path*" },
    { "source": "/app", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/app" },
    { "source": "/app/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/app/:path*" },
    { "source": "/admin", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/admin" },
    { "source": "/admin/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/admin/:path*" },
    { "source": "/login", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/login" },
    { "source": "/auth/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/auth/:path*" },
    { "source": "/api/audit/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/api/audit/:path*" },
    { "source": "/_next/:path*", "destination": "https://tsd-modernization-solutions-uc71.vercel.app/_next/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

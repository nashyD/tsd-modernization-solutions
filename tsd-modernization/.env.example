# Copy to .env.local (gitignored) for local dev, or set in Vercel → Project → Settings → Environment Variables.
# All three are optional — set only the ones you use. Variables MUST be prefixed with VITE_ to be exposed to the browser.

# Web3Forms — contact form submission endpoint key.
VITE_WEB3FORMS_KEY=

# Google Analytics 4 — measurement ID, format "G-XXXXXXXXXX".
# Get from Admin → Data Streams → (your web stream) → Measurement ID.
VITE_GA4_ID=

# Plausible — the site-specific script token from your Plausible install snippet.
# Found in the script URL: https://plausible.io/js/{THIS_PART}.js
# e.g. pa-R3jO3KFcDkvH79c2b6_2J
VITE_PLAUSIBLE_ID=

# Microsoft Clarity — project ID from clarity.microsoft.com → project settings.
VITE_CLARITY_ID=

# Sentry — frontend error monitoring DSN. Format:
# https://<key>@<org>.ingest.sentry.io/<project-id>
# Get from Sentry → Project → Settings → Client Keys (DSN). Public token, safe to ship in the browser bundle.
VITE_SENTRY_DSN=

# Anthropic API key — server-side only, used by /api/agent (the TSD chat agent).
# NO VITE_ prefix on purpose: this key MUST stay out of the browser bundle. Set it in
# Vercel → Project → Settings → Environment Variables. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# Public site URL the app is deployed at (used in Resend email links + Supabase magic-link redirects).
# Local dev: http://localhost:3000
# Production: https://tsd-modernization.com (after Vite-site rewrites land)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
# Get these from app.supabase.com > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API
# claude-sonnet-4-6 is the default; bump to opus for harder synthesis if quality demands.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Places API (Places API New, "Find Place" + "Place Details")
# Console: console.cloud.google.com > APIs & Services > Credentials
GOOGLE_PLACES_API_KEY=

# Resend transactional email
# Dashboard: resend.com > API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL="TSD Modernization Solutions <audit@tsd-modernization.com>"

# Upstash Redis for rate-limiting /api/audit/run
# Dashboard: console.upstash.com > Redis > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Internal shared secret. Pipeline runner (/api/audit/run) requires this header so the audit form's
# fire-and-forget kick can be authenticated; an attacker can't bypass rate limits by hitting it directly.
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=

# Bearer for the nightly sales loop's /api/loop/* routes (funnel read, queue_slots
# write, leadscout candidate import). On the loop's Mac the same value lives in the
# login keychain under service "tsd-loop-api". Generate with: openssl rand -hex 32
LOOP_API_SECRET=

# Vercel API token for /app/deployment (Phase 3). Read-only scope.
# Dashboard: vercel.com/account/tokens
VERCEL_API_TOKEN=

# Vapi public key for Web SDK (Phase 3, browser-safe per Vapi docs)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Per-rep Calendly booking links (all optional). Unset = Nash's fit-call event
# with ?utm_source=<owner> attribution. Set one to route that rep's prospects
# to their own calendar.
CALENDLY_URL_NASH=
CALENDLY_URL_GRANT=
CALENDLY_URL_BISHOP=

# Worker URL for Phase 4 monthly snapshots (Railway deployment URL)
WORKER_URL=
WORKER_SECRET=

# Square (sales-dashboard deposits). Dashboard: developer.squareup.com > your app.
# Use sandbox credentials until go-live, then set SQUARE_ENV=production and swap the token.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox
# Webhook signature key from the Square webhook subscription (Notifications > Webhooks).
SQUARE_WEBHOOK_SIGNATURE_KEY=
